# Paths
VAMOS_DATA_DIR=./data

# API
API_HOST=0.0.0.0
API_PORT=8247
API_CORS_ORIGINS=http://localhost:4247

# Web
WEB_PORT=4247
NEXT_PUBLIC_API_URL=http://localhost:8247
